{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3OperationsBoundary",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:ListBucketVersions",
        "s3:GetBucketVersioning",
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:DeleteBucket",
        "kms:DescribeKey",
        "kms:DeleteAlias",
        "kms:ScheduleKeyDeletion",
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    }
  ]
}
