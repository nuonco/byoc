{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "RdsClusterDestruction",
      "Effect": "Allow",
      "Action": [
        "rds:DeleteDBInstance",
        "rds:DeleteDBCluster"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/install.nuon.co/id": "{{ .nuon.install.id }}"
        }
      }
    }
  ]
}
